{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guardx.dev/schemas/policy.schema.json",
  "title": "GuardX Policy",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "const": "guardx/v1" },
    "kind": { "const": "Policy" },
    "metadata": {
      "type": "object",
      "required": ["id", "version", "tenant", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
          "description": "Immutable slug, unique per tenant."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semver. Every change = new version."
        },
        "tenant": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["draft", "in_review", "approved", "deprecated", "revoked"]
        },
        "profile": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" },
        "change_note": { "type": "string" },
        "parent_version": { "type": "string" },
        "origin": {
          "type": "string",
          "enum": ["manual", "feed", "synthesizer", "autotuner"],
          "default": "manual"
        },
        "origin_ref": { "type": "object" }
      }
    },
    "spec": {
      "type": "object",
      "required": ["applies_to", "guards"],
      "additionalProperties": false,
      "properties": {
        "applies_to": {
          "type": "object",
          "required": ["apps", "environments"],
          "additionalProperties": false,
          "properties": {
            "apps": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "environments": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          }
        },
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fail_mode": { "$ref": "#/$defs/failMode" },
            "timeout_ms": { "type": "integer", "minimum": 1, "maximum": 60000 }
          }
        },
        "guards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/guard" }
        }
      }
    }
  },
  "$defs": {
    "failMode": {
      "type": "string",
      "enum": ["open", "closed"],
      "description": "closed = block on detector error; open = pass + flag."
    },
    "scenario": {
      "type": "string",
      "enum": ["pii", "secrets", "hallucination", "content_safety"]
    },
    "direction": {
      "type": "array",
      "items": { "type": "string", "enum": ["input", "output"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "onFail": {
      "type": "string",
      "enum": ["block", "redact", "rewrite", "flag", "reask", "block_and_explain", "mask"]
    },
    "evidenceMode": {
      "type": "string",
      "enum": ["none", "spans", "full_text"]
    },
    "guard": {
      "type": "object",
      "required": ["id", "scenario", "detector", "direction", "on_fail"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^g-[a-z0-9][a-z0-9-]*$" },
        "scenario": { "$ref": "#/$defs/scenario" },
        "detector": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$",
          "description": "detector_id@version — pinned."
        },
        "direction": { "$ref": "#/$defs/direction" },
        "config": { "type": "object" },
        "threshold": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "const": "default" }
          ]
        },
        "on_fail": { "$ref": "#/$defs/onFail" },
        "evidence": { "$ref": "#/$defs/evidenceMode" },
        "fail_mode": { "$ref": "#/$defs/failMode" },
        "shadow": {
          "type": "boolean",
          "default": false,
          "description": "M3+: evaluate non-blocking, log shadow_verdict."
        },
        "provenance": {
          "type": "array",
          "description": "M5 synthesizer: source anchors + rule text for auditor review.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "anchor": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "page": { "type": "integer", "minimum": 0 },
                  "para": { "type": "integer", "minimum": 0 }
                }
              },
              "rule_text": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
