# Copy to `.env` and fill in real values. `.env` is git-ignored.
# --- Registry / Control API ---
# Full Postgres URI. Either bare 'postgresql://' or driver-qualified
# 'postgresql+psycopg://' is accepted — the Control API normalizes on load.
# For Supabase free tier use the Session Pooler URI from Project Settings →
# Database → Direct → Session pooler.
POSTGRES_URI=postgresql://postgres:PASSWORD@localhost:5432/postgres

# Alternate name honored by the Control API. Same URI; use whichever you like.
# GUARDX_DATABASE_URL=

# --- Auth (dev) ---
# Static API keys used until OIDC lands in M4. Regenerate for any shared env.
GUARDX_API_KEY_ADMIN=dev-admin-key
GUARDX_API_KEY_SERVICE=dev-service-key

# --- Signing (dev) ---
# Path to the Ed25519 keyfile used to sign bundles + chain anchors. Auto-
# generated on first run if absent. Production replaces this with a KMS /
# Vault Transit signer via the Signer protocol.
GUARDX_SIGNING_KEY_PATH=./dev-signing-key.ed25519
GUARDX_SIGNING_KEY_ID=dev-local

# Max bundle age in hours before the gateway enters per-guard fail_mode
# posture (spec §3.2 staleness guard).
GUARDX_BUNDLE_MAX_AGE_HOURS=72

# CORS: comma-separated list of allowed origins for the browser console.
# Empty (prod default) means same-origin only. Set to your console URL(s).
GUARDX_CORS_ALLOWED_ORIGINS=

# --- OIDC (spec §3.3). See docs/runbooks/oidc-setup.md ------------------------
# Enable real OIDC bearer-token auth. When off (default), the legacy
# X-GuardX-Key path is the only credential accepted. When on, both work:
# Bearer wins over X-GuardX-Key so a user's token isn't shadowed by a service
# key in the caller's environment.
GUARDX_OIDC_ENABLED=false
GUARDX_OIDC_ISSUER=
GUARDX_OIDC_AUDIENCE=
GUARDX_OIDC_JWKS_URL=
GUARDX_OIDC_ROLE_CLAIM=app_metadata.guardx_role
GUARDX_OIDC_SUBJECT_CLAIM=sub
GUARDX_OIDC_LEEWAY_SECONDS=30
GUARDX_OIDC_JWKS_TTL_SECONDS=900

# --- Console (Vite build-time; only VITE_ prefixed vars are exposed) ---------
# VITE_CONTROL_URL=http://localhost:8080
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# --- Gateway ---
# GUARDX_GATEWAY_ADDR=:8081
# GUARDX_CONTROL_BASE_URL=http://localhost:8080
# GUARDX_CONTROL_API_KEY=dev-service-key
# GUARDX_TENANT=acme
# GUARDX_ENV=prod
# GUARDX_UPSTREAM_BASE_URL=http://upstream:9000
# GUARDX_PII_BACKEND_URL=http://pii:9100
# GUARDX_BUNDLE_POLL_INTERVAL=2s

# --- Evidence pipeline (M2) ---
# Where the gateway posts decision events. Defaults to GUARDX_CONTROL_BASE_URL.
# GUARDX_EVIDENCE_BASE_URL=http://localhost:8080
# Disk spool used when the API is unreachable or the queue is full.
# GUARDX_EVIDENCE_SPOOL=/var/lib/guardx/evidence.spool.jsonl
# Set to 1 to fall back to stdout emitter (useful in tests).
# GUARDX_EVIDENCE_DISABLE_HTTP=0

# --- Supabase (only used if you point the API at a Supabase project) ---
# Not required by GuardX itself. Reserved here so `.env` can hold everything.
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# SUPABASE_JWKS_URL=

# --- Third-party services ---
# Together.ai key (only if you wire the M3 LLM-judge shim at it).
# TOGETHER_AI_API_KEY=
