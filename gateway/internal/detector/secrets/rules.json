{
  "title": "secretscan core",
  "version": "0.1.0",
  "rules": [
    {
      "id": "aws-access-key",
      "description": "AWS access key ID",
      "regex": "\\b(AKIA|ASIA|AGPA|AROA|AIDA|ANPA|ANVA|APKA)[A-Z0-9]{16}\\b",
      "keywords": ["AKIA", "ASIA", "AGPA", "AROA", "AIDA", "ANPA", "ANVA", "APKA"],
      "confidence": 0.98
    },
    {
      "id": "aws-secret-key",
      "description": "AWS secret access key (contextual)",
      "regex": "(?i)aws.{0,30}(secret|access)?[_-]?key['\"]?\\s*[:=]\\s*['\"]?([A-Za-z0-9/+=]{40})['\"]?",
      "keywords": ["aws"],
      "confidence": 0.90
    },
    {
      "id": "github-pat",
      "description": "GitHub personal access token",
      "regex": "\\bghp_[A-Za-z0-9]{36}\\b",
      "keywords": ["ghp_"],
      "confidence": 0.99
    },
    {
      "id": "github-oauth",
      "description": "GitHub OAuth token",
      "regex": "\\bgho_[A-Za-z0-9]{36}\\b",
      "keywords": ["gho_"],
      "confidence": 0.99
    },
    {
      "id": "github-app-token",
      "description": "GitHub App installation token",
      "regex": "\\b(ghs_|ghu_)[A-Za-z0-9]{36}\\b",
      "keywords": ["ghs_", "ghu_"],
      "confidence": 0.99
    },
    {
      "id": "slack-token",
      "description": "Slack bot/user/app token",
      "regex": "\\bxox[baprs]-[A-Za-z0-9-]{10,72}\\b",
      "keywords": ["xoxb-", "xoxa-", "xoxp-", "xoxr-", "xoxs-"],
      "confidence": 0.98
    },
    {
      "id": "stripe-secret",
      "description": "Stripe secret key",
      "regex": "\\bsk_(live|test)_[A-Za-z0-9]{24,}\\b",
      "keywords": ["sk_live_", "sk_test_"],
      "confidence": 0.99
    },
    {
      "id": "google-api-key",
      "description": "Google API key",
      "regex": "\\bAIza[0-9A-Za-z_\\-]{35}\\b",
      "keywords": ["AIza"],
      "confidence": 0.95
    },
    {
      "id": "openai-api-key",
      "description": "OpenAI API key",
      "regex": "\\bsk-[A-Za-z0-9]{32,}\\b",
      "keywords": ["sk-"],
      "confidence": 0.90
    },
    {
      "id": "jwt",
      "description": "JSON Web Token",
      "regex": "\\bey[A-Za-z0-9_-]{10,}\\.ey[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b",
      "keywords": ["ey"],
      "confidence": 0.85,
      "validators": ["jwt_structural"]
    },
    {
      "id": "private-key-pem",
      "description": "PEM-encoded private key",
      "regex": "-----BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY( BLOCK)?-----",
      "keywords": ["BEGIN"],
      "confidence": 1.0
    },
    {
      "id": "generic-high-entropy",
      "description": "High-entropy base64/hex fallback",
      "regex": "\\b[A-Za-z0-9+/=_-]{24,}\\b",
      "keywords": [],
      "confidence": 0.55,
      "entropy_min": 4.5
    }
  ]
}
